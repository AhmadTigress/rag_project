/*
 * LLMOps Test-Only Pipeline
 * * This pipeline runs tests on every push without requiring Azure credentials.
 * * Pipeline stages:
 * - Checkout code from Git
 * - Setup Python environment
 * - Install dependencies via uv sync
 * - Run tests with coverage
 */

pipeline {
    agent any
    
    environment {
        // Python settings
        PYTHON_VERSION = '3.12'
        PYTHONPATH = "${WORKSPACE}:${WORKSPACE}/multi_doc_chat"
        
        // API Keys for testing (optional - set in Jenkins if needed)
        GROQ_API_KEY = "${env.GROQ_API_KEY ?: ''}"
        GOOGLE_API_KEY = "${env.GOOGLE_API_KEY ?: ''}"
        HF_TOKEN = "${env.HF_TOKEN ?: ''}"
        LLM_PROVIDER = "${env.LLM_PROVIDER ?: 'huggingface'}"
    }
    
    triggers {
        // Poll SCM approximately every minute (no GitHub webhook/tunnel needed)
        pollSCM('* * * * *')
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo '📦 Checking out code from repository...'
                checkout scm
            }
        }
        
        stage('Setup Python Environment') {
            steps {
                echo '🐍 Setting up Python via uv...'
                sh '''
                    set -e
                    
                    # Install uv (fast Python package/dependency manager)
                    curl -LsSf https://astral.sh/uv/install.sh | sh
                    UV="$HOME/.local/bin/uv"

                    # Avoid Azure Files limitations by storing uv data outside Jenkins HOME
                    export UV_PYTHON_INSTALL_DIR=/tmp/uv/python
                    export XDG_DATA_HOME=/tmp/.local/share
                    export XDG_CACHE_HOME=/tmp/.cache
                    
                    # Ensure exact Python version matches project (e.g., 3.12)
                    "$UV" python install ${PYTHON_VERSION}
                '''
            }
        }
        
        stage('Install Dependencies') {
            steps {
                echo '📥 Syncing project workspace environment from uv.lock...'
                sh '''
                    set -e
                    UV="$HOME/.local/bin/uv"

                    # Ensure uv uses temp storage during dependency installation
                    export UV_PYTHON_INSTALL_DIR=/tmp/uv/python
                    export XDG_DATA_HOME=/tmp/.local/share
                    export XDG_CACHE_HOME=/tmp/.cache
                    
                    # --- NATIVE INTEGRATION ---
                    # Instruct uv to compile and manage the virtual environment inside /tmp
                    export UV_PROJECT_ENVIRONMENT="/tmp/venv-${BUILD_NUMBER}"
                    
                    # Direct uv to search the specialized PyTorch CPU wheel registry
                    export UV_EXTRA_INDEX_URL="https://download.pytorch.org/whl/cpu"
                    
                    # Synchronizes the virtual environment to perfectly match uv.lock
                    # Includes production dependencies and dev dependencies (pytest, pytest-cov) natively
                    # --frozen forces the build to fail if uv.lock is missing or out of sync
                    "$UV" sync --frozen
                    
                    echo "Using PYTHONPATH=${PYTHONPATH} for local package imports"
                '''
            }
        }
        
        stage('Run Tests') {
            steps {
                echo '🧪 Running pytest tests via uv run...'
                sh '''
                    set -e
                    mkdir -p test-results
                    
                    # Bind back to the isolated virtual environment path in /tmp
                    export UV_PROJECT_ENVIRONMENT="/tmp/venv-${BUILD_NUMBER}"
                    
                    # 'uv run' automatically wraps execution inside your sync'd lockfile environment
                    $HOME/.local/bin/uv run pytest tests/ \
                        --verbose \
                        --junit-xml=test-results/results.xml \
                        --cov=multi_doc_chat \
                        --cov-report=xml:coverage.xml \
                        --cov-report=html:htmlcov \
                        --cov-report=term \
                        || true
                '''
                
                // Archive test results and coverage reports immediately
                echo '📊 Archiving test results...'
                junit allowEmptyResults: true, testResults: 'test-results/*.xml'
                archiveArtifacts artifacts: 'coverage.xml,htmlcov/**,test-results/**/*.xml', allowEmptyArchive: true
            }
        }
    }
    
    post {
        success {
            echo '✅ Pipeline completed successfully! 🎉'
            echo '📊 Test results and coverage reports have been archived.'
        }
        
        failure {
            echo '❌ Pipeline failed!'
            echo 'Check the console output above for error details.'
        }
        
        always {
            echo '🧹 Cleaning up virtual environment...'
            sh 'rm -rf /tmp/venv-${BUILD_NUMBER} || true'
            echo '💡 Pipeline execution finished.'
        }
    }
}