/*
 * LLMOps Test-Only Pipeline
 * * This pipeline runs tests on every push without requiring Azure credentials.
 * * Pipeline stages:
 * - Checkout code from Git
 * - Setup Python environment
 * - Install dependencies via uv sync
 * - Run tests with coverage
 */

pipeline {
    agent any
    
    environment {
        // Python settings
        PYTHON_VERSION = '3.12'
        PYTHONPATH = "${WORKSPACE}:${WORKSPACE}/multi_doc_chat" [cite: 12]
        
        // API Keys for testing (optional - set in Jenkins if needed)
        GROQ_API_KEY = "${env.GROQ_API_KEY ?: ''}" [cite: 13]
        GOOGLE_API_KEY = "${env.GOOGLE_API_KEY ?: ''}" [cite: 13]
        HF_TOKEN = "${env.HF_TOKEN ?: ''}" [cite: 13]
        LLM_PROVIDER = "${env.LLM_PROVIDER ?: 'huggingface'}" // Fixed unclosed quote typo 
    }
    
    triggers {
        // Poll SCM approximately every minute (no GitHub webhook/tunnel needed)
        pollSCM('* * * * *') [cite: 14]
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo '📦 Checking out code from repository...' [cite: 14]
                checkout scm [cite: 14]
            }
        }
        
        stage('Setup Python Environment') {
            steps {
                echo '🐍 Setting up Python via uv...' [cite: 15]
                sh '''
                    set -e [cite: 15]
                    
                    # Install uv (fast Python package/dependency manager)
                    curl -LsSf https://astral.sh/uv/install.sh | sh [cite: 16, 17]
                    UV="$HOME/.local/bin/uv" [cite: 17]

                    # Avoid Azure Files limitations by storing uv data outside Jenkins HOME
                    export UV_PYTHON_INSTALL_DIR=/tmp/uv/python [cite: 17]
                    export XDG_DATA_HOME=/tmp/.local/share [cite: 17]
                    export XDG_CACHE_HOME=/tmp/.cache [cite: 18]
                    
                    # Ensure exact Python version matches project (e.g., 3.12)
                    "$UV" python install ${PYTHON_VERSION} [cite: 18]
                '''
            }
        }
        
        stage('Install Dependencies') {
            steps {
                echo '📥 Syncing project workspace environment from uv.lock...' [cite: 21]
                sh '''
                    set -e [cite: 21]
                    UV="$HOME/.local/bin/uv" [cite: 22]

                    # Ensure uv uses temp storage during dependency installation
                    export UV_PYTHON_INSTALL_DIR=/tmp/uv/python [cite: 17]
                    export XDG_DATA_HOME=/tmp/.local/share [cite: 22]
                    export XDG_CACHE_HOME=/tmp/.cache [cite: 22]
                    
                    # --- NATIVE INTEGRATION ---
                    # Instruct uv to compile and manage the virtual environment inside /tmp
                    export UV_PROJECT_ENVIRONMENT="/tmp/venv-${BUILD_NUMBER}" [cite: 19]
                    
                    # Direct uv to search the specialized PyTorch CPU wheel registry
                    export UV_EXTRA_INDEX_URL="https://download.pytorch.org/whl/cpu"
                    
                    # Synchronizes the virtual environment to perfectly match uv.lock
                    # Includes production dependencies and dev dependencies (pytest, pytest-cov) natively
                    # --frozen forces the build to fail if uv.lock is missing or out of sync
                    "$UV" sync --frozen
                    
                    echo "Using PYTHONPATH=${PYTHONPATH} for local package imports" [cite: 28]
                '''
            }
        }
        
        stage('Run Tests') {
            steps {
                echo '🧪 Running pytest tests via uv run...' [cite: 29]
                sh '''
                    set -e [cite: 29]
                    mkdir -p test-results [cite: 30]
                    
                    # Bind back to the isolated virtual environment path in /tmp
                    export UV_PROJECT_ENVIRONMENT="/tmp/venv-${BUILD_NUMBER}" [cite: 19]
                    
                    # 'uv run' automatically wraps execution inside your sync'd lockfile environment
                    $HOME/.local/bin/uv run pytest tests/ \
                        --verbose \
                        --junit-xml=test-results/results.xml \
                        --cov=multi_doc_chat \
                        --cov-report=xml:coverage.xml \
                        --cov-report=html:htmlcov \
                        --cov-report=term \
                        || true [cite: 30, 31, 32, 33]
                '''
                
                // Archive test results and coverage reports immediately
                echo '📊 Archiving test results...' [cite: 33]
                junit allowEmptyResults: true, testResults: 'test-results/*.xml' [cite: 33]
                archiveArtifacts artifacts: 'coverage.xml,htmlcov/**,test-results/**/*.xml', allowEmptyArchive: true [cite: 34]
            }
        }
    }
    
    post {
        success {
            echo '✅ Pipeline completed successfully! 🎉' [cite: 34, 35]
            echo '📊 Test results and coverage reports have been archived.' [cite: 35]
        }
        
        failure {
            echo '❌ Pipeline failed!' [cite: 36]
            echo 'Check the console output above for error details.' [cite: 37]
        }
        
        always {
            echo '🧹 Cleaning up virtual environment...' [cite: 38]
            sh 'rm -rf /tmp/venv-${BUILD_NUMBER} || true' [cite: 38]
            echo '💡 Pipeline execution finished.' [cite: 38, 39]
        }
    }
}